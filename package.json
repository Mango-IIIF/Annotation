{
  "name": "@mango-iiif/annotation",
  "version": "0.0.3",
  "description": "Framework-agnostic OpenSeadragon annotation editor.",
  "license": "MIT",
  "type": "module",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "npm run build:lib && npm run build:types",
    "build:lib": "vite build",
    "build:types": "tsc -p tsconfig.build.json",
    "prepack": "npm run build",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "openseadragon": "^5.0.1"
  },
  "devDependencies": {
    "@types/node": "^24.1.0",
    "@types/openseadragon": "^5.0.2",
    "jsdom": "^27.0.1",
    "openseadragon": "^5.0.1",
    "typescript": "~5.9.3",
    "vite": "^8.0.16",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "@mango-iiif/w3c-parser": "^0.0.1"
  }
}
